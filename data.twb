      <aliases enabled='yes' />
      <column caption='Moving average difference' datatype='real' name='[Calculation_2282480598767763459]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(&#13;&#10;    WINDOW_AVG(SUM([priceByArea]), -2, 0)&#13;&#10;    - LOOKUP(WINDOW_AVG(SUM([priceByArea]), -2, 0), -1)&#13;&#10;)&#13;&#10;/ &#13;&#10;ABS(LOOKUP(WINDOW_AVG(SUM([priceByArea]), -2, 0), -1)) * 100'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Exterior_count' datatype='integer' name='[Calculation_585467988659286020]' role='measure' type='quantitative'>
